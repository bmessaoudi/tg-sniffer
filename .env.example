# =============================================================================
# TELEGRAM CHANNEL COPIER - CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values

# -----------------------------------------------------------------------------
# TELEGRAM API CREDENTIALS
# Get these from https://my.telegram.org
# -----------------------------------------------------------------------------
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# -----------------------------------------------------------------------------
# TELEGRAM SESSION STRING
# This is generated when you first login with your Telegram account
# It allows the bot to stay logged in without requiring phone number each time
# -----------------------------------------------------------------------------
TELEGRAM_STRING_SESSION=your_session_string_here

# -----------------------------------------------------------------------------
# SOURCE CHANNELS
# Comma-separated list of channel names OR channel IDs to copy messages FROM
# You can mix names and IDs
# Examples:
#   SOURCE_CHANNELS=My Channel Name
#   SOURCE_CHANNELS=1234567890
#   SOURCE_CHANNELS=Channel 1,Channel 2,1234567890
# -----------------------------------------------------------------------------
SOURCE_CHANNELS=Channel Name Here

# -----------------------------------------------------------------------------
# DESTINATION CHANNELS
# Comma-separated list of channel IDs where messages will be sent TO
# Must be numeric IDs (not usernames)
# Examples:
#   DESTINATION_CHANNEL_IDS=1234567890
#   DESTINATION_CHANNEL_IDS=1234567890,0987654321,1122334455
# -----------------------------------------------------------------------------
DESTINATION_CHANNEL_IDS=1234567890

# -----------------------------------------------------------------------------
# COPY CONTROL
# Enable or disable actual message copying
# Set to 'true' to enable copying, 'false' for dry-run mode (just logging)
# Useful for testing before going live with a client
# -----------------------------------------------------------------------------
COPY_ENABLED=false

# -----------------------------------------------------------------------------
# BLOCKED WORDS
# Comma-separated list of words/phrases that block message copying
# If a message contains ANY of these words (case-insensitive), it won't be copied
# Example: "zoom.us,meet.google.com,teams.microsoft.com,discord.gg"
# -----------------------------------------------------------------------------
BLOCKED_WORDS=zoom.us,zoom.com
