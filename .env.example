# =============================================================================
# TELEGRAM CHANNEL COPIER - CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values

# -----------------------------------------------------------------------------
# TELEGRAM API CREDENTIALS
# Get these from https://my.telegram.org
# -----------------------------------------------------------------------------
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# -----------------------------------------------------------------------------
# TELEGRAM SESSION STRING
# This is generated when you first login with your Telegram account
# It allows the bot to stay logged in without requiring phone number each time
# -----------------------------------------------------------------------------
TELEGRAM_STRING_SESSION=your_session_string_here

# -----------------------------------------------------------------------------
# SESSION FILE (OPTIONAL)
# Path (without .session extension) for the persistent SQLite session file.
# On first run, the session is bootstrapped from TELEGRAM_STRING_SESSION and
# saved to this file. On subsequent runs, the file is used directly, which
# persists update state (pts) and eliminates delays for supergroup/forum topics.
# Default: tg-sniffer (creates tg-sniffer.session in the working directory)
# -----------------------------------------------------------------------------
# SESSION_FILE=tg-sniffer

# -----------------------------------------------------------------------------
# SOURCE CHANNELS
# Comma-separated list of channel names OR channel IDs to copy messages FROM
# You can mix names and IDs
# Examples:
#   SOURCE_CHANNELS=My Channel Name
#   SOURCE_CHANNELS=1234567890
#   SOURCE_CHANNELS=Channel 1,Channel 2,1234567890
# -----------------------------------------------------------------------------
SOURCE_CHANNELS=Channel Name Here

# -----------------------------------------------------------------------------
# DESTINATION CHANNELS
# Comma-separated list of channel IDs where messages will be sent TO
# Must be numeric IDs (not usernames)
# Examples:
#   DESTINATION_CHANNEL_IDS=1234567890
#   DESTINATION_CHANNEL_IDS=1234567890,0987654321,1122334455
# -----------------------------------------------------------------------------
DESTINATION_CHANNEL_IDS=1234567890

# -----------------------------------------------------------------------------
# COPY CONTROL
# Enable or disable actual message copying
# Set to 'true' to enable copying, 'false' for dry-run mode (just logging)
# Useful for testing before going live with a client
# -----------------------------------------------------------------------------
COPY_ENABLED=false

# -----------------------------------------------------------------------------
# BLOCKED WORDS
# Comma-separated list of words/phrases that block message copying
# If a message contains ANY of these words (case-insensitive), it won't be copied
# Example: "zoom.us,meet.google.com,teams.microsoft.com,discord.gg"
# -----------------------------------------------------------------------------
BLOCKED_WORDS=zoom.us,zoom.com

# -----------------------------------------------------------------------------
# PER-SOURCE ROUTING (ADVANCED)
# If set, overrides SOURCE_CHANNELS + DESTINATION_CHANNEL_IDS
# Format: source->dest1,dest2;source2/topic_id->dest3
# Separator between rules: ;
# Separator between destinations: ,
# Topic filter: source_id/topic_id (only forward messages from that forum topic)
#
# Examples:
#   # Single source to single destination
#   CHANNEL_ROUTES=SourceChannel->-100123456
#
#   # Multiple sources, each to different destinations
#   CHANNEL_ROUTES=SourceA->-100123456,-100789012;SourceB->-100999999
#
#   # Forum topic filter: only topic 42 from a supergroup
#   CHANNEL_ROUTES=-100555555/42->-100999999
#
#   # Mix: broadcast + topic filter
#   CHANNEL_ROUTES=SourceA->-100123456,-100789012;-100555555/42->-100999999
#
#   # Media control: by default only text is forwarded (media-only messages are skipped).
#   # Add +media to a source to forward full messages including images/videos/documents.
#   CHANNEL_ROUTES=SourceA+media->-100123456;SourceB->-100789012
#
#   # +media with topic filter
#   CHANNEL_ROUTES=-100555555/42+media->-100999999
# -----------------------------------------------------------------------------
# CHANNEL_ROUTES=
